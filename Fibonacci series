* Fibonacci Series using dynamic programming
public class Main{
    public static int fibo(int n){
        int dp[]=new int[n+2];
        dp[0]=0;
        dp[1]=1;
        for(int i = 2; i<=n; i++){
            dp[i]= dp[i-1] + dp[i-2];
        }
        return dp[n];
    }
	public static void main(String[] args) {
	     int n = 5;
	     for(int i = 0; i<n; i++){
	          System.out.print(fibo(i)+" ");
	     }
	}
}
