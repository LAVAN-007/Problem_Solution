//Maximum Sum Subarray of Size K
import java.util.*;
public class Main{
    public int subarraySum(int arr[], int k){
        if(arr.length < k){
            return 0;
        }
        int current_sum = 0;
        for(int i = 0; i < k; i++ ){
            current_sum+=arr[i];
        }
        int max = current_sum;
        for(int i = k; i < arr.length; i++){
            current_sum = current_sum - arr[i-k] + arr[i];
            
            if(current_sum > max){
                max = current_sum;
            }
        }
        return max;
    }
    
    
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		int n = sc.nextInt();
		int arr[]=new int[n];
		for(int i=0; i<n; i++){
		    arr[i]=sc.nextInt();
		}
		int k = sc.nextInt();
		Main myObj = new Main();
		System.out.println(myObj.subarraySum(arr,k));
		
	}
}
